<?xml version="1.0" encoding="UTF-8"?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:behaviors="clr-namespace:ImageGenerator.MAUI.Presentation.Behaviors"
             xmlns:converters="clr-namespace:ImageGenerator.MAUI.Presentation.Converters"
             xmlns:vm="clr-namespace:ImageGenerator.MAUI.Presentation.ViewModels"
             xmlns:lib="clr-namespace:ImageGenerator.MAUI.Core.Domain.Ideogram.Mutation.Library"
             x:Class="ImageGenerator.MAUI.Presentation.Views.MutationEnginePage"
             x:DataType="vm:MutationEngineViewModel"
             Title="Mutation engine"
             Shell.NavBarIsVisible="True"
             Padding="0">
    <ContentPage.Resources>
        <ResourceDictionary>
            <converters:NonEmptyStringToBoolConverter x:Key="NonEmptyStringToBool" />
        </ResourceDictionary>
    </ContentPage.Resources>

    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="16">

            <!-- Header -->
            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                <Button Grid.Column="0"
                        Text="← Back"
                        Clicked="OnBackClicked"
                        Style="{StaticResource SecondaryButton}"
                        VerticalOptions="Start"
                        AutomationId="MutationBackButton" />
                <VerticalStackLayout Grid.Column="1" Spacing="4" VerticalOptions="Center">
                    <Label Text="Mutate a structured prompt" Style="{StaticResource CardTitle}" />
                    <Label Text="Turn the current caption into N one-change variants, then render them all as a batch. Pick winners in the gallery and promote one to full quality via Remix."
                           Style="{StaticResource HelperText}" />
                    <Label Text="{Binding SettingsEcho}"
                           Style="{StaticResource HelperText}"
                           IsVisible="{Binding SettingsEcho, Converter={StaticResource NonEmptyStringToBool}}" />
                </VerticalStackLayout>
            </Grid>

            <!-- CARD: Engine (Deterministic / AI) -->
            <Border Style="{StaticResource Card}">
                <VerticalStackLayout Spacing="8">
                    <Label Text="Mutation engine" Style="{StaticResource FieldLabel}" />
                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                        <Switch Grid.Column="0" IsToggled="{Binding IsAiMode}" VerticalOptions="Center"
                                AutomationId="MutationAiModeSwitch" />
                        <Label Grid.Column="1" VerticalOptions="Center"
                               Text="AI (LLM) mutation — coherent, directed variants from a free-text steer. Off = the deterministic engine (free, reproducible)." />
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <!-- BANNER: breeding from gallery winners (set by the "Breed selected" hand-off) -->
            <Border Style="{StaticResource Card}" IsVisible="{Binding IsBreedMode}">
                <Label Text="{Binding BreedSummary}"
                       Style="{StaticResource FieldLabel}"
                       LineBreakMode="WordWrap"
                       AutomationId="MutationBreedBanner" />
            </Border>

            <!-- CARD: AI steer (AI mode only) -->
            <Border Style="{StaticResource Card}" IsVisible="{Binding IsAiMode}">
                <VerticalStackLayout Spacing="12">
                    <Label Text="Describe the change" Style="{StaticResource FieldLabel}" />
                    <Editor Text="{Binding Steer}"
                            Placeholder="e.g. make it winter · 1970s film look · explore a bold art movement"
                            AutoSize="TextChanges"
                            MinimumHeightRequest="72"
                            AutomationId="MutationSteerEditor" />
                    <Picker Title="Start from a preset…"
                            ItemsSource="{Binding AnchorPresets}"
                            ItemDisplayBinding="{Binding Name, x:DataType=lib:AnchorPreset}"
                            SelectedItem="{Binding SelectedAnchorPreset}"
                            AutomationId="MutationAnchorPresetPicker" />
                    <Label Text="Optional: a preset fills the steer with a starting direction — edit it freely afterward." Style="{StaticResource HelperText}" />
                    <Label Text="The model rewrites the WHOLE caption coherently for each variant (medium, lighting, palette and every element together)." Style="{StaticResource HelperText}" />

                    <Label Text="Model" Style="{StaticResource FieldLabel}" />
                    <Picker ItemsSource="{Binding ModelTierOptions}"
                            SelectedItem="{Binding SelectedModelTier}"
                            AutomationId="MutationModelTierPicker" />
                    <Label Text="Sonnet = affordable default · Opus = stronger/pricier · Local = free Ollama (verifies the round-trip; quality not guaranteed)."
                           Style="{StaticResource HelperText}" />

                    <!-- Local-only: which Ollama model. Type any tag, or Refresh to pick from the server. -->
                    <VerticalStackLayout Spacing="8" IsVisible="{Binding IsLocalTier}">
                        <Label Text="Local model (Ollama)" Style="{StaticResource FieldLabel}" />
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                            <Picker Grid.Column="0"
                                    ItemsSource="{Binding Generator.OllamaModels}"
                                    SelectedItem="{Binding Generator.OllamaModel, Mode=TwoWay}"
                                    Title="Refresh, then pick a model…"
                                    AutomationId="MutationOllamaModelPicker" />
                            <Button Grid.Column="1"
                                    Text="Refresh"
                                    Command="{Binding Generator.RefreshOllamaModelsCommand}"
                                    Style="{StaticResource SecondaryButton}"
                                    AutomationId="MutationOllamaRefreshButton" />
                        </Grid>
                        <Label Text="Set the server URL on the Settings page. A 27B model takes a few minutes on the first (cold) call."
                               Style="{StaticResource HelperText}" />
                    </VerticalStackLayout>

                    <Label Text="{Binding CostEstimate}" Style="{StaticResource HelperText}"
                           AutomationId="MutationCostEstimateLabel" />
                </VerticalStackLayout>
            </Border>

            <!-- CARD: Axis (deterministic only) -->
            <Border Style="{StaticResource Card}" IsVisible="{Binding IsDeterministicMode}">
                <VerticalStackLayout Spacing="8">
                    <Label Text="Axis to vary" Style="{StaticResource FieldLabel}" />
                    <Picker ItemsSource="{Binding AxisOptions}"
                            SelectedItem="{Binding SelectedAxis}"
                            AutomationId="MutationAxisPicker" />
                    <Label Text="LOOK varies style + ornament (placement pinned). SCENE varies background, placement, and elements (style pinned). One axis per run keeps each difference traceable."
                           Style="{StaticResource HelperText}" />

                    <Label Text="Operators that will run" Style="{StaticResource FieldLabel}" Margin="0,8,0,0" />
                    <VerticalStackLayout BindableLayout.ItemsSource="{Binding OperatorsForAxis}" Spacing="2">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate x:DataType="x:String">
                                <Label Text="{Binding ., StringFormat='• {0}'}" Style="{StaticResource HelperText}" />
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Border>

            <!-- CARD: Saved style (deterministic LOOK swap, or AI restyle — hidden in breed mode) -->
            <Border Style="{StaticResource Card}" IsVisible="{Binding ShowStylePin}">
                <VerticalStackLayout Spacing="8">
                    <Label Text="Saved style" Style="{StaticResource FieldLabel}" />
                    <Picker ItemsSource="{Binding StyleNames}"
                            SelectedItem="{Binding SelectedStyleName}"
                            AutomationId="MutationStylePinPicker" />
                    <Label Text="Render in a specific saved style instead of varying it. Deterministic LOOK swaps to it exactly; AI rewrites the whole scene into it coherently. “Any style (random)” varies the style per variant. Save styles via the gallery’s “Save style”."
                           Style="{StaticResource HelperText}" />
                </VerticalStackLayout>
            </Border>

            <!-- CARD: Run settings -->
            <Border Style="{StaticResource Card}">
                <VerticalStackLayout Spacing="12">
                    <Label Text="Number of variants (1–100)" Style="{StaticResource FieldLabel}" />
                    <Entry Text="{Binding Count}" Keyboard="Numeric" AutomationId="MutationCountEntry">
                        <Entry.Behaviors><behaviors:NumericOnlyBehavior /></Entry.Behaviors>
                    </Entry>

                    <VerticalStackLayout Spacing="4" IsVisible="{Binding ShowStrength}">
                        <Label Text="Placement strength" Style="{StaticResource FieldLabel}" />
                        <Picker ItemsSource="{Binding StrengthOptions}"
                                SelectedItem="{Binding SelectedStrength}"
                                AutomationId="MutationStrengthPicker" />
                        <Label Text="How far bbox/placement operators move boxes (subtle / moderate / bold = 2 / 5 / 10% of the grid)."
                               Style="{StaticResource HelperText}" />
                    </VerticalStackLayout>

                    <HorizontalStackLayout Spacing="8" IsVisible="{Binding IsDeterministicMode}">
                        <CheckBox IsChecked="{Binding IncludeBase}" VerticalOptions="Center"
                                  AutomationId="MutationIncludeBaseCheckBox" />
                        <Label Text="Include the unmutated base as a reference (variant 0)" VerticalOptions="Center" />
                    </HorizontalStackLayout>

                    <Label Text="Seed" Style="{StaticResource FieldLabel}" />
                    <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
                        <Entry Grid.Column="0" Text="{Binding Seed}" Keyboard="Numeric" AutomationId="MutationSeedEntry">
                            <Entry.Behaviors><behaviors:NumericOnlyBehavior /></Entry.Behaviors>
                        </Entry>
                        <Button Grid.Column="1" Text="Randomize" Command="{Binding RandomizeSeedCommand}"
                                Style="{StaticResource SecondaryButton}" AutomationId="MutationRandomizeSeedButton" />
                        <Button Grid.Column="2" Text="Copy" Command="{Binding CopySeedCommand}"
                                Style="{StaticResource SecondaryButton}" AutomationId="MutationCopySeedButton" />
                    </Grid>
                    <Label Text="Same base + same seed ⇒ identical variants. Every variant (and the base) renders at this one seed, so only the mutation differs."
                           Style="{StaticResource HelperText}" IsVisible="{Binding IsDeterministicMode}" />
                    <Label Text="The render seed is pinned across the batch so only the caption differs. AI variants are not reproducible (no model seed)."
                           Style="{StaticResource HelperText}" IsVisible="{Binding IsAiMode}" />
                </VerticalStackLayout>
            </Border>

            <!-- CARD: Slot-tag review -->
            <Border Style="{StaticResource Card}" IsVisible="{Binding HasBase}">
                <VerticalStackLayout Spacing="8">
                    <Label Text="What may change in each element" Style="{StaticResource FieldLabel}" />
                    <Label Text="Each row is one element from your prompt. Its tag decides which part a mutation may touch — leave it on “Auto” to let the app guess from the wording, or pick one. The subject's face/identity is always left untouched."
                           Style="{StaticResource HelperText}" />
                    <CollectionView ItemsSource="{Binding SlotReview}" AutomationId="MutationSlotReviewList">
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="vm:MutationSlotReviewItem">
                                <Grid ColumnDefinitions="*,260" ColumnSpacing="8" Padding="0,4">
                                    <Label Grid.Column="0" Text="{Binding Summary}" VerticalOptions="Center"
                                           LineBreakMode="TailTruncation" />
                                    <Picker Grid.Column="1" ItemsSource="{Binding Options}"
                                            SelectedItem="{Binding SelectedTag}" />
                                </Grid>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
            </Border>

            <!-- Generate (deterministic) -->
            <Button Text="Generate variants"
                    Command="{Binding GenerateCommand}"
                    Style="{StaticResource PrimaryButton}"
                    HorizontalOptions="Fill"
                    IsVisible="{Binding IsDeterministicMode}"
                    AutomationId="MutationGenerateButton" />

            <!-- Mutate (AI) -->
            <Button Text="Mutate with AI"
                    Command="{Binding MutateWithAiCommand}"
                    Style="{StaticResource PrimaryButton}"
                    HorizontalOptions="Fill"
                    IsVisible="{Binding IsAiMode}"
                    AutomationId="MutationMutateWithAiButton" />

            <Label Text="{Binding StatusMessage}"
                   Style="{StaticResource StatusLabel}"
                   IsVisible="{Binding StatusMessage, Converter={StaticResource NonEmptyStringToBool}}"
                   LineBreakMode="WordWrap"
                   AutomationId="MutationStatusLabel">
                <Label.Triggers>
                    <DataTrigger TargetType="Label" Binding="{Binding StatusKind}" Value="{x:Static vm:StatusKind.Success}">
                        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource StatusSuccessLight}, Dark={StaticResource StatusSuccessDark}}" />
                    </DataTrigger>
                    <DataTrigger TargetType="Label" Binding="{Binding StatusKind}" Value="{x:Static vm:StatusKind.Error}">
                        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource StatusErrorLight}, Dark={StaticResource StatusErrorDark}}" />
                    </DataTrigger>
                    <DataTrigger TargetType="Label" Binding="{Binding StatusKind}" Value="{x:Static vm:StatusKind.Warning}">
                        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource StatusWarningLight}, Dark={StaticResource StatusWarningDark}}" />
                    </DataTrigger>
                </Label.Triggers>
            </Label>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
