<?xml version="1.0" encoding="UTF-8"?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:behaviors="clr-namespace:ImageGenerator.MAUI.Presentation.Behaviors"
             xmlns:converters="clr-namespace:ImageGenerator.MAUI.Presentation.Converters"
             xmlns:vm="clr-namespace:ImageGenerator.MAUI.Presentation.ViewModels"
             x:Class="ImageGenerator.MAUI.Presentation.Views.MainPage"
             x:DataType="vm:GeneratorViewModel"
             Shell.NavBarIsVisible="False"
             Padding="0">
    <ContentPage.Resources>
        <ResourceDictionary>
            <converters:StringToEnumConverter x:Key="StringToEnumConverter" />
            <converters:InverseBoolConverter x:Key="InverseBool" />
            <converters:NonEmptyStringToBoolConverter x:Key="NonEmptyStringToBool" />
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid x:Name="RootGrid"
          ColumnDefinitions="*"
          RowDefinitions="*,Auto">
        <VisualStateManager.VisualStateGroups>
            <VisualStateGroup x:Name="LayoutStates">
                <VisualState x:Name="Narrow">
                    <VisualState.StateTriggers>
                        <AdaptiveTrigger MinWindowWidth="0" />
                    </VisualState.StateTriggers>
                    <VisualState.Setters>
                        <Setter Property="ColumnDefinitions" Value="*" />
                        <Setter Property="RowDefinitions" Value="*,Auto" />
                    </VisualState.Setters>
                </VisualState>
                <VisualState x:Name="Wide">
                    <VisualState.StateTriggers>
                        <AdaptiveTrigger MinWindowWidth="1000" />
                    </VisualState.StateTriggers>
                    <VisualState.Setters>
                        <Setter Property="ColumnDefinitions" Value="460,*" />
                        <Setter Property="RowDefinitions" Value="*" />
                    </VisualState.Setters>
                </VisualState>
            </VisualStateGroup>
        </VisualStateManager.VisualStateGroups>

        <!-- LEFT RAIL: scrollable controls + pinned action bar -->
        <Grid Grid.Row="0" Grid.Column="0" RowDefinitions="*,Auto">
            <ScrollView Grid.Row="0" Style="{StaticResource LeftRailScroll}">
                <VerticalStackLayout Spacing="16" Padding="0,0,10,16">

                    <!-- Page header -->
            <VerticalStackLayout Spacing="4">
                <Label Text="AI Image Generator" Style="{StaticResource PageTitle}" />
                <Label Text="Generate images via Replicate (Flux) or OpenAI. Prompt and parameters are embedded into the saved file."
                       Style="{StaticResource PageSubtitle}" />
            </VerticalStackLayout>

            <!-- 2-column card grid. Fixed columns with * sizing so it adapts to window width. -->
            <Grid ColumnDefinitions="*,*"
                  RowDefinitions="Auto,Auto"
                  ColumnSpacing="16"
                  RowSpacing="16">

                <!-- ROW 0 -->
                <!-- CARD: API Token -->
                <Border Grid.Row="0" Grid.Column="0"
                        Style="{StaticResource Card}"
                        VerticalOptions="Start">
                    <VerticalStackLayout Spacing="8">
                        <Label Text="API Token" Style="{StaticResource CardTitle}" />
                        <Label Text="Replicate or OpenAI — masked; never sent anywhere except the API endpoint."
                               Style="{StaticResource HelperText}" />
                        <Entry Text="{Binding Parameters.ApiToken}"
                               Placeholder="Paste your API token…"
                               IsPassword="True"
                               SemanticProperties.Description="API token"
                               AutomationId="ApiTokenEntry" />
                        <Button Text="Forget token"
                                Command="{Binding ForgetTokenCommand}"
                                Style="{StaticResource SecondaryButton}"
                                IsEnabled="{Binding Parameters.ApiToken, Converter={StaticResource NonEmptyStringToBool}}"
                                HorizontalOptions="Start"
                                SemanticProperties.Description="Clear the saved API token from secure storage"
                                AutomationId="ForgetTokenButton" />
                    </VerticalStackLayout>
                </Border>

                <!-- CARD: Prompt & Model (cascading Provider + Model pickers) -->
                <Border Grid.Row="0" Grid.Column="1"
                        Style="{StaticResource Card}"
                        VerticalOptions="Start">
                    <VerticalStackLayout Spacing="12">
                        <Label Text="Prompt" Style="{StaticResource CardTitle}" />

                        <Grid ColumnDefinitions="*,*,Auto"
                              RowDefinitions="Auto,Auto"
                              ColumnSpacing="12"
                              RowSpacing="4">
                            <Label Grid.Row="0" Grid.Column="0" Text="Provider" Style="{StaticResource FieldLabel}" />
                            <Picker Grid.Row="1" Grid.Column="0"
                                    ItemsSource="{Binding Providers}"
                                    SelectedItem="{Binding SelectedProvider}"
                                    AutomationId="ProviderPicker" />
                            <Label Grid.Row="0" Grid.Column="1" Text="Model" Style="{StaticResource FieldLabel}" />
                            <Picker Grid.Row="1" Grid.Column="1"
                                    ItemsSource="{Binding FilteredModels}"
                                    ItemDisplayBinding="{Binding Display}"
                                    SelectedItem="{Binding SelectedModel}"
                                    AutomationId="ModelPicker" />
                            <Button Grid.Row="1" Grid.Column="2"
                                    Text="Refresh"
                                    Style="{StaticResource SecondaryButton}"
                                    Command="{Binding RefreshModelsCommand}"
                                    IsEnabled="{Binding Parameters.ApiToken, Converter={StaticResource NonEmptyStringToBool}}"
                                    VerticalOptions="End"
                                    SemanticProperties.Description="Fetch live model catalogs from Replicate and OpenAI"
                                    AutomationId="RefreshModelsButton" />
                        </Grid>

                        <Label Text="What should the image show?" Style="{StaticResource FieldLabel}" />
                        <Editor Text="{Binding Parameters.Prompt}"
                                Placeholder="Describe the image you want to generate…"
                                AutoSize="TextChanges"
                                MinimumHeightRequest="90"
                                AutomationId="PromptEditor" />

                        <HorizontalStackLayout Spacing="8" IsVisible="{Binding SupportsPromptUpsampling}">
                            <CheckBox IsChecked="{Binding Parameters.PromptUpsampling}" VerticalOptions="Center" />
                            <Label Text="Prompt upsampling" VerticalOptions="Center" />
                        </HorizontalStackLayout>
                    </VerticalStackLayout>
                </Border>

                <!-- ROW 1 -->
                <!-- CARD: Input Image (optional) -->
                <Border Grid.Row="1" Grid.Column="0"
                        Style="{StaticResource Card}"
                        VerticalOptions="Start"
                        IsVisible="{Binding SupportsImagePrompt}">
                    <VerticalStackLayout Spacing="12">
                        <Label Text="{Binding ImagePromptCardTitle}" Style="{StaticResource CardTitle}" />
                        <Label Text="Optional reference image(s). Max count and payload field vary by model."
                               Style="{StaticResource HelperText}" />

                        <CollectionView ItemsSource="{Binding SelectedImages}"
                                        ItemsLayout="HorizontalList"
                                        HeightRequest="140"
                                        IsVisible="{Binding InputImageCount, Converter={StaticResource IntGreaterThanZero}}">
                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="vm:GeneratorViewModel+InputImageItem">
                                    <Grid Padding="4" WidthRequest="140" HeightRequest="140">
                                        <Image Source="{Binding Preview}" Aspect="AspectFill"
                                               SemanticProperties.Description="{Binding FileName}" />
                                        <Button Text="×" FontSize="14" Padding="0"
                                                WidthRequest="28" HeightRequest="28"
                                                HorizontalOptions="End" VerticalOptions="Start"
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type vm:GeneratorViewModel}}, Path=RemoveImageCommand}"
                                                CommandParameter="{Binding .}"
                                                AutomationId="RemoveImageButton" />
                                    </Grid>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>

                        <HorizontalStackLayout Spacing="8">
                            <Button Text="Add image"
                                    Command="{Binding AddImageCommand}"
                                    IsEnabled="{Binding CanAddImage}"
                                    Style="{StaticResource SecondaryButton}"
                                    AutomationId="AddImageButton" />
                            <Button Text="Clear all"
                                    Command="{Binding ClearImagesCommand}"
                                    IsVisible="{Binding InputImageCount, Converter={StaticResource IntGreaterThanZero}}"
                                    Style="{StaticResource SecondaryButton}"
                                    AutomationId="ClearImagesButton" />
                        </HorizontalStackLayout>

                        <Label Text="{Binding Parameters.ImagePromptStrength, StringFormat='Image prompt strength: {0:F2}'}"
                               Style="{StaticResource FieldLabel}"
                               IsVisible="{Binding SupportsImagePromptStrength}" />
                        <Slider Minimum="0" Maximum="1"
                                Value="{Binding Parameters.ImagePromptStrength, Mode=TwoWay}"
                                HorizontalOptions="Fill"
                                IsVisible="{Binding SupportsImagePromptStrength}" />
                    </VerticalStackLayout>
                </Border>

                <!-- CARD: Output (aspect, resolution, format, quality, safety, seed) -->
                <Border Grid.Row="1" Grid.Column="1"
                        Style="{StaticResource Card}"
                        VerticalOptions="Start">
                    <VerticalStackLayout Spacing="12">
                        <Label Text="Output" Style="{StaticResource CardTitle}" />

                        <VerticalStackLayout Spacing="4" IsVisible="{Binding SupportsAspectRatio}">
                            <Label Text="{Binding AspectRatioLabel}" Style="{StaticResource FieldLabel}" />
                            <Picker ItemsSource="{Binding AspectRatioOptions}"
                                    SelectedItem="{Binding Parameters.AspectRatio}"
                                    MaximumWidthRequest="220"
                                    HorizontalOptions="Start"
                                    AutomationId="AspectRatioPicker" />
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="4" IsVisible="{Binding SupportsResolution}">
                            <Label Text="Resolution" Style="{StaticResource FieldLabel}" />
                            <Picker ItemsSource="{Binding ResolutionOptions}"
                                    SelectedItem="{Binding Parameters.Resolution}"
                                    MaximumWidthRequest="140"
                                    HorizontalOptions="Start"
                                    AutomationId="ResolutionPicker" />
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="8" IsVisible="{Binding SupportsCustomDimensions}">
                            <Label Text="Custom dimensions (px)" Style="{StaticResource FieldLabel}" />
                            <Label Text="64 - 2048 px. Flux 1.1 Pro model range: 256 - 1440."
                                   Style="{StaticResource HelperText}" />
                            <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                                <VerticalStackLayout Grid.Column="0" Spacing="4">
                                    <Label Text="Width" Style="{StaticResource HelperText}" />
                                    <Entry Text="{Binding Parameters.Width}" Keyboard="Numeric">
                                        <Entry.Behaviors>
                                            <behaviors:NumericOnlyBehavior />
                                        </Entry.Behaviors>
                                    </Entry>
                                </VerticalStackLayout>
                                <VerticalStackLayout Grid.Column="1" Spacing="4">
                                    <Label Text="Height" Style="{StaticResource HelperText}" />
                                    <Entry Text="{Binding Parameters.Height}" Keyboard="Numeric">
                                        <Entry.Behaviors>
                                            <behaviors:NumericOnlyBehavior />
                                        </Entry.Behaviors>
                                    </Entry>
                                </VerticalStackLayout>
                            </Grid>
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="4">
                            <Label Text="Output format" Style="{StaticResource FieldLabel}" />
                            <Picker ItemsSource="{Binding OutputFormats}"
                                    SelectedItem="{Binding Parameters.OutputFormat, Converter={StaticResource StringToEnumConverter}}"
                                    MaximumWidthRequest="140"
                                    HorizontalOptions="Start" />
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="4" IsVisible="{Binding SupportsOutputQuality}">
                            <Label Text="{Binding Parameters.OutputQuality, StringFormat='Output quality: {0:F0}%'}"
                                   Style="{StaticResource FieldLabel}" />
                            <Slider Minimum="1" Maximum="100"
                                    Value="{Binding Parameters.OutputQuality, Mode=TwoWay}"
                                    HorizontalOptions="Fill" />
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="4" IsVisible="{Binding SupportsSafetyTolerance}">
                            <Label Text="{Binding Parameters.SafetyTolerance, StringFormat='Safety tolerance: {0:F0} (1 strictest — 6 loosest)'}"
                                   Style="{StaticResource FieldLabel}" />
                            <Slider Minimum="1" Maximum="6"
                                    Value="{Binding Parameters.SafetyTolerance, Mode=TwoWay}"
                                    HorizontalOptions="Fill" />
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="8" IsVisible="{Binding SupportsSeed}">
                            <Label Text="Seed" Style="{StaticResource FieldLabel}" />
                            <Label Text="Fixing the seed makes regeneration deterministic for the same prompt."
                                   Style="{StaticResource HelperText}" />
                            <Entry Text="{Binding Parameters.Seed}"
                                   Keyboard="Numeric"
                                   Placeholder="Seed">
                                <Entry.Behaviors>
                                    <behaviors:NumericOnlyBehavior />
                                </Entry.Behaviors>
                            </Entry>
                            <HorizontalStackLayout Spacing="8">
                                <CheckBox IsChecked="{Binding Parameters.RandomizeSeed}" VerticalOptions="Center" />
                                <Label Text="Randomize on each generation" VerticalOptions="Center" />
                            </HorizontalStackLayout>
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </Border>
            </Grid>

            <!-- CARD: GPT Image 1.5 advanced options (only visible when that model is selected) -->
            <Border Style="{StaticResource Card}"
                    IsVisible="{Binding SupportsGptQuality}">
                <VerticalStackLayout Spacing="12">
                    <Label Text="GPT Image 1.5 options" Style="{StaticResource CardTitle}" />
                    <Label Text="Fine-grained knobs the Replicate-hosted gpt-image-1.5 schema accepts."
                           Style="{StaticResource HelperText}" />

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="12" RowDefinitions="Auto,Auto" RowSpacing="12">
                        <VerticalStackLayout Grid.Row="0" Grid.Column="0" Spacing="4">
                            <Label Text="Quality" Style="{StaticResource FieldLabel}" />
                            <Picker ItemsSource="{Binding GptQualityOptions}"
                                    SelectedItem="{Binding Parameters.GptQuality}"
                                    AutomationId="GptQualityPicker" />
                        </VerticalStackLayout>
                        <VerticalStackLayout Grid.Row="0" Grid.Column="1" Spacing="4">
                            <Label Text="Background" Style="{StaticResource FieldLabel}" />
                            <Picker ItemsSource="{Binding GptBackgroundOptions}"
                                    SelectedItem="{Binding Parameters.GptBackground}"
                                    AutomationId="GptBackgroundPicker" />
                        </VerticalStackLayout>
                        <VerticalStackLayout Grid.Row="1" Grid.Column="0" Spacing="4">
                            <Label Text="Moderation" Style="{StaticResource FieldLabel}" />
                            <Picker ItemsSource="{Binding GptModerationOptions}"
                                    SelectedItem="{Binding Parameters.GptModeration}"
                                    AutomationId="GptModerationPicker" />
                        </VerticalStackLayout>
                        <VerticalStackLayout Grid.Row="1" Grid.Column="1" Spacing="4">
                            <Label Text="Input fidelity" Style="{StaticResource FieldLabel}" />
                            <Picker ItemsSource="{Binding GptInputFidelityOptions}"
                                    SelectedItem="{Binding Parameters.GptInputFidelity}"
                                    AutomationId="GptInputFidelityPicker" />
                        </VerticalStackLayout>
                    </Grid>
                </VerticalStackLayout>
            </Border>

                </VerticalStackLayout>
            </ScrollView>

            <!-- PINNED ACTION BAR: Generate / Cancel / Status — always visible at the bottom of the left rail -->
            <Border Grid.Row="1" Style="{StaticResource LeftRailActionBar}">
                <VerticalStackLayout Spacing="8">
                    <!-- Idle: Generate -->
                    <VerticalStackLayout Spacing="6"
                                         IsVisible="{Binding IsGenerating, Converter={StaticResource InverseBool}}">
                        <Button Text="Generate Image"
                                Style="{StaticResource PrimaryButton}"
                                Command="{Binding GenerateImageCommand}"
                                HorizontalOptions="Fill"
                                SemanticProperties.Description="Start image generation"
                                AutomationId="GenerateButton">
                            <Button.Triggers>
                                <!-- Visual-only disabled look when required fields are missing.
                                     The button stays clickable so tapping surfaces an explicit
                                     "what's missing" message rather than MAUI's focus-jump. -->
                                <DataTrigger TargetType="Button" Binding="{Binding IsValid}" Value="False">
                                    <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray600}}" />
                                    <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray300}}" />
                                    <Setter Property="Opacity" Value="0.85" />
                                </DataTrigger>
                            </Button.Triggers>
                        </Button>
                        <Label Text="Fill in API Token and a prompt to enable generation."
                               Style="{StaticResource HelperText}"
                               IsVisible="{Binding IsValid, Converter={StaticResource InverseBool}}" />
                    </VerticalStackLayout>

                    <!-- Generating: spinner + Cancel -->
                    <Grid ColumnDefinitions="*,Auto"
                          ColumnSpacing="12"
                          IsVisible="{Binding IsGenerating}">
                        <HorizontalStackLayout Grid.Column="0" Spacing="12" VerticalOptions="Center">
                            <ActivityIndicator IsRunning="{Binding IsGenerating}"
                                               VerticalOptions="Center"
                                               HeightRequest="20"
                                               WidthRequest="20" />
                            <Label Text="Working…" VerticalOptions="Center" />
                        </HorizontalStackLayout>
                        <Button Grid.Column="1"
                                Text="Cancel"
                                Style="{StaticResource DangerButton}"
                                Command="{Binding GenerateImageCancelCommand}"
                                SemanticProperties.Description="Cancel in-flight image generation"
                                AutomationId="CancelButton" />
                    </Grid>

                    <!-- Status (theme-aware via DataTriggers) -->
                    <Label Text="{Binding StatusMessage}"
                           Style="{StaticResource StatusLabel}"
                           LineBreakMode="TailTruncation"
                           MaxLines="2"
                           AutomationId="StatusLabel">
                        <Label.Triggers>
                            <DataTrigger TargetType="Label" Binding="{Binding StatusKind}" Value="{x:Static vm:StatusKind.Success}">
                                <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource StatusSuccessLight}, Dark={StaticResource StatusSuccessDark}}" />
                            </DataTrigger>
                            <DataTrigger TargetType="Label" Binding="{Binding StatusKind}" Value="{x:Static vm:StatusKind.Error}">
                                <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource StatusErrorLight}, Dark={StaticResource StatusErrorDark}}" />
                            </DataTrigger>
                            <DataTrigger TargetType="Label" Binding="{Binding StatusKind}" Value="{x:Static vm:StatusKind.Warning}">
                                <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource StatusWarningLight}, Dark={StaticResource StatusWarningDark}}" />
                            </DataTrigger>
                            <DataTrigger TargetType="Label" Binding="{Binding StatusKind}" Value="{x:Static vm:StatusKind.Canceled}">
                                <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource StatusCanceledLight}, Dark={StaticResource StatusCanceledDark}}" />
                            </DataTrigger>
                            <DataTrigger TargetType="Label" Binding="{Binding StatusKind}" Value="{x:Static vm:StatusKind.Info}">
                                <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource StatusInfoLight}, Dark={StaticResource StatusInfoDark}}" />
                            </DataTrigger>
                        </Label.Triggers>
                    </Label>
                </VerticalStackLayout>
            </Border>
        </Grid>

        <!-- RIGHT PANE: persistent result canvas. Own VSM swaps Grid.Row/Grid.Column to stack below the left rail on narrow windows. -->
        <Border x:Name="RightPane" Style="{StaticResource ResultCanvas}">
            <VisualStateManager.VisualStateGroups>
                <VisualStateGroup x:Name="PanePlacement">
                    <VisualState x:Name="StackedBelow">
                        <VisualState.StateTriggers>
                            <AdaptiveTrigger MinWindowWidth="0" />
                        </VisualState.StateTriggers>
                        <VisualState.Setters>
                            <Setter Property="Grid.Row" Value="1" />
                            <Setter Property="Grid.Column" Value="0" />
                        </VisualState.Setters>
                    </VisualState>
                    <VisualState x:Name="SideBySide">
                        <VisualState.StateTriggers>
                            <AdaptiveTrigger MinWindowWidth="1000" />
                        </VisualState.StateTriggers>
                        <VisualState.Setters>
                            <Setter Property="Grid.Row" Value="0" />
                            <Setter Property="Grid.Column" Value="1" />
                        </VisualState.Setters>
                    </VisualState>
                </VisualStateGroup>
            </VisualStateManager.VisualStateGroups>
            <Grid RowDefinitions="Auto,*,Auto,Auto" RowSpacing="12">
                <Label Grid.Row="0" Text="Result" Style="{StaticResource CardTitle}" />

                <Image Grid.Row="1"
                       Source="{Binding GeneratedImagePath}"
                       Aspect="AspectFit"
                       HorizontalOptions="Fill"
                       VerticalOptions="Fill"
                       MinimumHeightRequest="240"
                       SemanticProperties.Description="Generated image preview">
                    <Image.Triggers>
                        <DataTrigger TargetType="Image" Binding="{Binding IsGenerating}" Value="True">
                            <Setter Property="Opacity" Value="0.5" />
                        </DataTrigger>
                    </Image.Triggers>
                </Image>

                <Label Grid.Row="2"
                       Text="{Binding Parameters.Prompt}"
                       Style="{StaticResource HelperText}"
                       MaxLines="3"
                       LineBreakMode="TailTruncation" />

                <HorizontalStackLayout Grid.Row="3" Spacing="8">
                    <Button Text="Use as input for next generation"
                            Command="{Binding UseGeneratedImageAsInputCommand}"
                            Style="{StaticResource ActionPrimary}"
                            AutomationId="UseAsInputButton">
                        <Button.Triggers>
                            <DataTrigger TargetType="Button" Binding="{Binding GeneratedImagePath}" Value="{x:Null}">
                                <Setter Property="IsVisible" Value="False" />
                            </DataTrigger>
                        </Button.Triggers>
                    </Button>
                    <Button Text="Show in folder"
                            Command="{Binding ShowInFolderCommand}"
                            Style="{StaticResource SecondaryButton}"
                            SemanticProperties.Description="Open the generated-images folder in Explorer"
                            AutomationId="ShowInFolderButton" />
                </HorizontalStackLayout>
            </Grid>
        </Border>
    </Grid>
</ContentPage>
