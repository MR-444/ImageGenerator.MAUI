<?xml version="1.0" encoding="UTF-8"?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:behaviors="clr-namespace:ImageGenerator.MAUI.Presentation.Behaviors"
             xmlns:converters="clr-namespace:ImageGenerator.MAUI.Presentation.Converters"
             xmlns:vm="clr-namespace:ImageGenerator.MAUI.Presentation.ViewModels"
             xmlns:vo="clr-namespace:ImageGenerator.MAUI.Core.Domain.ValueObjects"
             x:Name="Root"
             x:Class="ImageGenerator.MAUI.Presentation.Views.MainPage"
             x:DataType="vm:GeneratorViewModel"
             Shell.NavBarIsVisible="False"
             Padding="0">
    <ContentPage.Resources>
        <ResourceDictionary>
            <converters:StringToEnumConverter x:Key="StringToEnumConverter" />
            <converters:InverseBoolConverter x:Key="InverseBool" />
            <converters:NonEmptyStringToBoolConverter x:Key="NonEmptyStringToBool" />
            <converters:ResolutionAspectRatioConverter x:Key="ResolutionAspectRatio" />
        </ResourceDictionary>
    </ContentPage.Resources>

    <!-- Fixed header (row 0) and action bar (row 2); the two panes in row 1 scroll
         independently, so Generate and the status line never scroll out of view. -->
    <Grid RowDefinitions="Auto,*,Auto"
          Padding="24,16,24,12"
          RowSpacing="12">

        <!-- Page header -->
        <Grid Grid.Row="0" ColumnDefinitions="*,Auto,Auto" ColumnSpacing="12">
            <VerticalStackLayout Grid.Column="0" Spacing="4">
                <Label Text="AI Image Generator" Style="{StaticResource PageTitle}" />
                <Label Text="Generate images via Replicate or Pollinations. Prompt and parameters are embedded into the saved file."
                       Style="{StaticResource PageSubtitle}" />
            </VerticalStackLayout>
            <Button Grid.Column="1"
                    Text="Settings"
                    Style="{StaticResource SecondaryButton}"
                    Command="{Binding OpenSettingsCommand}"
                    VerticalOptions="Start"
                    SemanticProperties.Description="API tokens and ComfyUI server configuration"
                    AutomationId="SettingsButton" />
            <Button Grid.Column="2"
                    Text="About"
                    Style="{StaticResource SecondaryButton}"
                    Clicked="OnAboutClicked"
                    VerticalOptions="Start"
                    AutomationId="AboutButton" />
        </Grid>

        <!-- Two independently scrolling panes: settings left, queue/results right. -->
        <Grid Grid.Row="1"
              ColumnDefinitions="3*,2*"
              ColumnSpacing="16">

            <!-- SETTINGS PANE: two columns of cards stacking independently,
                 so a tall Prompt card in col 0 doesn't leave a gap below API Token in col 1. -->
            <ScrollView Grid.Column="0">
                <Grid ColumnDefinitions="*,*"
                      ColumnSpacing="16"
                      Padding="0,0,12,16">

                    <VerticalStackLayout Grid.Column="0" Spacing="16">

                    <!-- CARD: Prompt & Model -->
                    <Border Style="{StaticResource Card}"
                            VerticalOptions="Start">
                        <VerticalStackLayout Spacing="12">
                            <Label Text="Prompt" Style="{StaticResource CardTitle}" />

                            <Grid ColumnDefinitions="*,*"
                                  RowDefinitions="Auto,Auto"
                                  ColumnSpacing="12"
                                  RowSpacing="4">
                                <Label Grid.Row="0" Grid.Column="0" Text="Provider" Style="{StaticResource FieldLabel}" />
                                <Picker Grid.Row="1" Grid.Column="0"
                                        ItemsSource="{Binding ProviderFilter.Providers}"
                                        SelectedItem="{Binding ProviderFilter.SelectedProvider}"
                                        AutomationId="ProviderPicker" />
                                <Label Grid.Row="0" Grid.Column="1" Text="Model" Style="{StaticResource FieldLabel}" />
                                <Picker Grid.Row="1" Grid.Column="1"
                                        ItemsSource="{Binding ProviderFilter.FilteredModels}"
                                        SelectedItem="{Binding ProviderFilter.SelectedModel}"
                                        AutomationId="ModelPicker">
                                    <Picker.ItemDisplayBinding>
                                        <Binding Path="Display" x:DataType="vo:ModelOption" />
                                    </Picker.ItemDisplayBinding>
                                </Picker>
                            </Grid>

                            <Button Text="Refresh Models"
                                    Style="{StaticResource SecondaryButton}"
                                    Command="{Binding RefreshModelsCommand}"
                                    HorizontalOptions="Start"
                                    SemanticProperties.Description="Fetch live model catalogs from Replicate and Pollinations. Replicate models require an API token; Pollinations refreshes anonymously."
                                    AutomationId="RefreshModelsButton" />

                            <!-- One writer per direction: VM->view via OneWay binding, view->VM via the
                                 explicit TextChanged handler. The default TwoWay binding intermittently
                                 stopped pushing paste/clear/paste sequences into Parameters.Prompt on
                                 Windows, leaving validation (and generation!) on a stale prompt. -->
                            <Editor x:Name="PromptEditor"
                                    Text="{Binding Parameters.Prompt, Mode=OneWay}"
                                    TextChanged="OnPromptTextChanged"
                                    Placeholder="Describe the image you want to generate…"
                                    AutoSize="TextChanges"
                                    MinimumHeightRequest="90"
                                    MaximumHeightRequest="220"
                                    AutomationId="PromptEditor" />

                            <!-- Gated by JsonPromptEditor (not IdeogramOptions): Ideogram V4 AND
                                 ComfyUI workflow models both consume the structured caption JSON. -->
                            <VerticalStackLayout Spacing="2" IsVisible="{Binding SupportsJsonPromptEditor}">
                                <HorizontalStackLayout Spacing="8">
                                    <CheckBox IsChecked="{Binding Parameters.UseJsonPrompt}" VerticalOptions="Center"
                                              AutomationId="JsonPromptCheckBox" />
                                    <Label Text="Structured JSON prompt" VerticalOptions="Center" />
                                </HorizontalStackLayout>
                                <Label Text="Send the prompt box as a structured caption JSON (must be valid JSON)."
                                       Style="{StaticResource HelperText}" />
                                <Label Text="{Binding JsonPromptStateText}"
                                       Style="{StaticResource HelperText}"
                                       IsVisible="{Binding JsonPromptStateText, Converter={StaticResource NonEmptyStringToBool}}"
                                       AutomationId="JsonPromptStateLabel" />
                                <Button Text="Edit structure…"
                                        Command="{Binding OpenIdeogramEditorCommand}"
                                        Style="{StaticResource SecondaryButton}"
                                        HorizontalOptions="Start"
                                        Margin="0,6,0,0"
                                        SemanticProperties.Description="Open the visual builder for Ideogram's structured JSON prompt"
                                        AutomationId="EditStructureButton" />
                            </VerticalStackLayout>

                            <HorizontalStackLayout Spacing="8" IsVisible="{Binding Capabilities.PromptUpsampling}">
                                <CheckBox IsChecked="{Binding Parameters.PromptUpsampling}" VerticalOptions="Center" />
                                <Label Text="Prompt upsampling" VerticalOptions="Center" />
                            </HorizontalStackLayout>
                        </VerticalStackLayout>
                    </Border>

                    <!-- CARD: Input Image (optional) -->
                    <Border Style="{StaticResource Card}"
                            VerticalOptions="Start"
                            IsVisible="{Binding Capabilities.ImagePrompt}">
                        <Border.GestureRecognizers>
                            <DropGestureRecognizer AllowDrop="True"
                                                   DragOver="OnImageDragOver"
                                                   Drop="OnImageDropped" />
                        </Border.GestureRecognizers>
                        <VerticalStackLayout Spacing="12">
                            <Label Text="{Binding InputImages.ImagePromptCardTitle}" Style="{StaticResource CardTitle}" />
                            <Label Text="Optional reference image(s). Max count and payload field vary by model."
                                   Style="{StaticResource HelperText}" />

                            <CollectionView ItemsSource="{Binding InputImages.SelectedImages}"
                                            ItemsLayout="HorizontalList"
                                            HeightRequest="140"
                                            IsVisible="{Binding InputImages.InputImageCount, Converter={StaticResource IntGreaterThanZero}}">
                                <CollectionView.ItemTemplate>
                                    <DataTemplate x:DataType="vm:InputImagesCoordinator+InputImageItem">
                                        <Grid Padding="4" WidthRequest="140" HeightRequest="140">
                                            <Image Source="{Binding Preview}" Aspect="AspectFill"
                                                   SemanticProperties.Description="{Binding FileName}" />
                                            <Button Text="×" FontSize="14" Padding="0"
                                                    WidthRequest="28" HeightRequest="28"
                                                    HorizontalOptions="End" VerticalOptions="Start"
                                                    CommandParameter="{Binding .}"
                                                    Clicked="OnRemoveImageClicked"
                                                    AutomationId="RemoveImageButton" />
                                        </Grid>
                                    </DataTemplate>
                                </CollectionView.ItemTemplate>
                            </CollectionView>

                            <HorizontalStackLayout Spacing="8">
                                <Button Text="Add image"
                                        Command="{Binding InputImages.AddImageCommand}"
                                        IsEnabled="{Binding InputImages.CanAddImage}"
                                        Style="{StaticResource SecondaryButton}"
                                        AutomationId="AddImageButton" />
                                <Button Text="Clear all"
                                        Command="{Binding InputImages.ClearImagesCommand}"
                                        IsVisible="{Binding InputImages.InputImageCount, Converter={StaticResource IntGreaterThanZero}}"
                                        Style="{StaticResource SecondaryButton}"
                                        AutomationId="ClearImagesButton" />
                            </HorizontalStackLayout>

                            <Label Text="{Binding Parameters.ImagePromptStrength, StringFormat='Image prompt strength: {0:F2}'}"
                                   Style="{StaticResource FieldLabel}"
                                   IsVisible="{Binding InputImages.SupportsImagePromptStrength}" />
                            <Slider Minimum="0" Maximum="1"
                                    Value="{Binding Parameters.ImagePromptStrength, Mode=TwoWay}"
                                    HorizontalOptions="Fill"
                                    IsVisible="{Binding InputImages.SupportsImagePromptStrength}" />
                        </VerticalStackLayout>
                    </Border>

                    </VerticalStackLayout>

                    <VerticalStackLayout Grid.Column="1" Spacing="16">

                    <!-- CARD: Output (aspect, resolution, format, quality, safety, seed) -->
                    <Border Style="{StaticResource Card}"
                            VerticalOptions="Start">
                        <VerticalStackLayout Spacing="12">
                            <Label Text="Output" Style="{StaticResource CardTitle}" />

                            <VerticalStackLayout Spacing="4" IsVisible="{Binding Capabilities.AspectRatio}">
                                <Label Text="{Binding Capabilities.AspectRatioLabel}" Style="{StaticResource FieldLabel}" />
                                <Picker ItemsSource="{Binding AspectRatioOptions}"
                                        SelectedItem="{Binding Parameters.AspectRatio}"
                                        MaximumWidthRequest="220"
                                        HorizontalOptions="Start"
                                        AutomationId="AspectRatioPicker" />
                            </VerticalStackLayout>

                            <!-- Single resolution picker for ALL models. NEVER add a second Picker
                                 two-way bound to Parameters.Resolution: two simultaneously bound WinUI
                                 ComboBoxes ping-pong null/value through the shared source in a
                                 synchronous livelock (IsVisible only hides; bindings stay live). The
                                 converter decorates WxH values (Ideogram) and passes everything else
                                 ("Auto", "1K", "4.0 MP") through unchanged. -->
                            <VerticalStackLayout Spacing="4" IsVisible="{Binding SupportsResolution}">
                                <Label Text="Resolution" Style="{StaticResource FieldLabel}" />
                                <Picker ItemsSource="{Binding ResolutionOptions}"
                                        SelectedItem="{Binding Parameters.Resolution}"
                                        ItemDisplayBinding="{Binding Path=., Converter={StaticResource ResolutionAspectRatio}, x:DataType='x:String'}"
                                        MaximumWidthRequest="190"
                                        HorizontalOptions="Start"
                                        AutomationId="ResolutionPicker" />
                            </VerticalStackLayout>

                            <!-- ComfyUI only: server models from /object_info (cache fallback) —
                                 checkpoints OR the single swappable UNETLoader diffusion model
                                 (label switches by kind). First entry is the workflow's own
                                 baked-in file = no patch. Binds the VM-level SelectedCheckpoint,
                                 never Parameters directly — see the livelock warning above. -->
                            <VerticalStackLayout Spacing="4" IsVisible="{Binding SupportsCheckpoint}">
                                <Label Text="{Binding CheckpointLabel}" Style="{StaticResource FieldLabel}" />
                                <Picker ItemsSource="{Binding CheckpointOptions}"
                                        SelectedItem="{Binding SelectedCheckpoint}"
                                        MaximumWidthRequest="320"
                                        HorizontalOptions="Start"
                                        AutomationId="CheckpointPicker" />
                            </VerticalStackLayout>

                            <!-- ComfyUI only: quality preset from the workflow's single CustomCombo
                                 node. Options come from the file itself (option1..option4); first
                                 entry is the baked-in choice = no patch. Binds the VM-level
                                 SelectedQualityPreset, never Parameters directly. -->
                            <VerticalStackLayout Spacing="4" IsVisible="{Binding SupportsQualityPreset}">
                                <Label Text="Preset" Style="{StaticResource FieldLabel}" />
                                <Picker ItemsSource="{Binding QualityPresetOptions}"
                                        SelectedItem="{Binding SelectedQualityPreset}"
                                        MaximumWidthRequest="320"
                                        HorizontalOptions="Start"
                                        AutomationId="QualityPresetPicker" />
                            </VerticalStackLayout>

                            <!-- Ideogram V4: copyright detection -->
                            <HorizontalStackLayout Spacing="8" IsVisible="{Binding SupportsIdeogramOptions}">
                                <CheckBox IsChecked="{Binding Parameters.EnableCopyrightDetection}" VerticalOptions="Center"
                                          AutomationId="CopyrightDetectionCheckBox" />
                                <Label Text="Enable copyright detection" VerticalOptions="Center" />
                            </HorizontalStackLayout>

                            <VerticalStackLayout Spacing="8" IsVisible="{Binding SupportsCustomDimensions}">
                                <Label Text="Custom dimensions (px)" Style="{StaticResource FieldLabel}" />
                                <Label Text="64 - 2048 px. Flux 1.1 Pro model range: 256 - 1440."
                                       Style="{StaticResource HelperText}" />
                                <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                                    <VerticalStackLayout Grid.Column="0" Spacing="4">
                                        <Label Text="Width" Style="{StaticResource HelperText}" />
                                        <Entry Text="{Binding Parameters.Width}" Keyboard="Numeric">
                                            <Entry.Behaviors>
                                                <behaviors:NumericOnlyBehavior />
                                            </Entry.Behaviors>
                                        </Entry>
                                    </VerticalStackLayout>
                                    <VerticalStackLayout Grid.Column="1" Spacing="4">
                                        <Label Text="Height" Style="{StaticResource HelperText}" />
                                        <Entry Text="{Binding Parameters.Height}" Keyboard="Numeric">
                                            <Entry.Behaviors>
                                                <behaviors:NumericOnlyBehavior />
                                            </Entry.Behaviors>
                                        </Entry>
                                    </VerticalStackLayout>
                                </Grid>
                            </VerticalStackLayout>

                            <VerticalStackLayout Spacing="4"
                                                 IsVisible="{Binding Capabilities.OutputFormatSelectable}">
                                <Label Text="Output format" Style="{StaticResource FieldLabel}" />
                                <Picker ItemsSource="{Binding OutputFormats}"
                                        SelectedItem="{Binding Parameters.OutputFormat, Converter={StaticResource StringToEnumConverter}}"
                                        MaximumWidthRequest="140"
                                        HorizontalOptions="Start" />
                            </VerticalStackLayout>

                            <HorizontalStackLayout Spacing="8" IsVisible="{Binding Capabilities.Safe}">
                                <CheckBox IsChecked="{Binding Parameters.Safe}" VerticalOptions="Center" />
                                <Label Text="NSFW filter (safe=nsfw)" VerticalOptions="Center" />
                            </HorizontalStackLayout>

                            <VerticalStackLayout Spacing="4" IsVisible="{Binding Capabilities.OutputQuality}">
                                <Label Text="{Binding Parameters.OutputQuality, StringFormat='Output quality: {0:F0}%'}"
                                       Style="{StaticResource FieldLabel}" />
                                <Slider Minimum="1" Maximum="100"
                                        Value="{Binding Parameters.OutputQuality, Mode=TwoWay}"
                                        HorizontalOptions="Fill" />
                            </VerticalStackLayout>

                            <VerticalStackLayout Spacing="4" IsVisible="{Binding Capabilities.SafetyTolerance}">
                                <Label Text="{Binding Parameters.SafetyTolerance, StringFormat='Safety tolerance: {0:F0} (1 strictest — 6 loosest)'}"
                                       Style="{StaticResource FieldLabel}" />
                                <Slider Minimum="1" Maximum="6"
                                        Value="{Binding Parameters.SafetyTolerance, Mode=TwoWay}"
                                        HorizontalOptions="Fill" />
                            </VerticalStackLayout>

                            <VerticalStackLayout Spacing="8" IsVisible="{Binding Capabilities.Seed}">
                                <Label Text="Seed" Style="{StaticResource FieldLabel}" />
                                <Label Text="Fixing the seed makes regeneration deterministic for the same prompt."
                                       Style="{StaticResource HelperText}" />
                                <Entry Text="{Binding Parameters.Seed}"
                                       Keyboard="Numeric"
                                       Placeholder="Seed">
                                    <Entry.Behaviors>
                                        <behaviors:NumericOnlyBehavior />
                                    </Entry.Behaviors>
                                </Entry>
                                <HorizontalStackLayout Spacing="8">
                                    <CheckBox IsChecked="{Binding Parameters.RandomizeSeed}" VerticalOptions="Center" />
                                    <Label Text="Randomize on each generation" VerticalOptions="Center" />
                                </HorizontalStackLayout>
                            </VerticalStackLayout>

                            <!-- CivitAI draft posting (provider-independent; defaults off each launch). -->
                            <VerticalStackLayout Spacing="2">
                                <HorizontalStackLayout Spacing="8">
                                    <CheckBox IsChecked="{Binding Parameters.PostToCivitai}"
                                              VerticalOptions="Center"
                                              AutomationId="PostToCivitaiCheckBox" />
                                    <Label Text="Post to CivitAI" VerticalOptions="Center" />
                                </HorizontalStackLayout>
                                <Label Text="Publishes the saved image on CivitAI right after generation — one step, no manual publish. Needs a CivitAI API key (Settings)."
                                       Style="{StaticResource HelperText}" />
                                <HorizontalStackLayout Spacing="8" Margin="36,0,0,0">
                                    <CheckBox IsChecked="{Binding Parameters.CivitaiIncludeMeta}"
                                              IsEnabled="{Binding Parameters.PostToCivitai}"
                                              VerticalOptions="Center"
                                              AutomationId="CivitaiIncludeMetaCheckBox" />
                                    <Label Text="Include generation data (prompt, seed, model)" VerticalOptions="Center" />
                                </HorizontalStackLayout>
                                <Label Text="Sent as structured metadata with the post; the local file is never modified."
                                       Style="{StaticResource HelperText}"
                                       Margin="36,0,0,0" />
                                <VerticalStackLayout Spacing="4" Margin="36,8,0,0">
                                    <Label Text="Post to model gallery (optional)" Style="{StaticResource FieldLabel}" />
                                    <Entry Text="{Binding Parameters.CivitaiModelRef}"
                                           IsEnabled="{Binding Parameters.PostToCivitai}"
                                           Placeholder="Model URL with modelVersionId=… or the bare version id"
                                           SemanticProperties.Description="CivitAI model the post should be associated with"
                                           AutomationId="CivitaiModelRefEntry" />
                                    <Label Text="Paste the model page URL (it carries modelVersionId) — posts land in that model's gallery. Empty = plain profile post. Remembered across sessions."
                                           Style="{StaticResource HelperText}" />
                                </VerticalStackLayout>
                            </VerticalStackLayout>
                        </VerticalStackLayout>
                    </Border>

                    <!-- CARD: GPT Image 1.5 advanced options (only visible when that model is selected) -->
                    <Border Style="{StaticResource Card}"
                            VerticalOptions="Start"
                            IsVisible="{Binding SupportsGptQuality}">
                        <VerticalStackLayout Spacing="12">
                            <Label Text="GPT Image 1.5 options" Style="{StaticResource CardTitle}" />
                            <Label Text="Fine-grained knobs the Replicate-hosted gpt-image-1.5 schema accepts."
                                   Style="{StaticResource HelperText}" />

                            <Grid ColumnDefinitions="*,*" ColumnSpacing="12" RowDefinitions="Auto,Auto" RowSpacing="12">
                                <VerticalStackLayout Grid.Row="0" Grid.Column="0" Spacing="4">
                                    <Label Text="Quality" Style="{StaticResource FieldLabel}" />
                                    <Picker ItemsSource="{Binding GptQualityOptions}"
                                            SelectedItem="{Binding Parameters.GptQuality}"
                                            AutomationId="GptQualityPicker" />
                                </VerticalStackLayout>
                                <VerticalStackLayout Grid.Row="0" Grid.Column="1" Spacing="4">
                                    <Label Text="Background" Style="{StaticResource FieldLabel}" />
                                    <Picker ItemsSource="{Binding GptBackgroundOptions}"
                                            SelectedItem="{Binding Parameters.GptBackground}"
                                            AutomationId="GptBackgroundPicker" />
                                </VerticalStackLayout>
                                <VerticalStackLayout Grid.Row="1" Grid.Column="0" Spacing="4">
                                    <Label Text="Moderation" Style="{StaticResource FieldLabel}" />
                                    <Picker ItemsSource="{Binding GptModerationOptions}"
                                            SelectedItem="{Binding Parameters.GptModeration}"
                                            AutomationId="GptModerationPicker" />
                                </VerticalStackLayout>
                                <VerticalStackLayout Grid.Row="1" Grid.Column="1" Spacing="4">
                                    <Label Text="Input fidelity" Style="{StaticResource FieldLabel}" />
                                    <Picker ItemsSource="{Binding GptInputFidelityOptions}"
                                            SelectedItem="{Binding Parameters.GptInputFidelity}"
                                            AutomationId="GptInputFidelityPicker" />
                                </VerticalStackLayout>
                            </Grid>
                        </VerticalStackLayout>
                    </Border>

                    </VerticalStackLayout>
                </Grid>
            </ScrollView>

            <!-- QUEUE / RESULTS PANE -->
            <ScrollView Grid.Column="1">
                <VerticalStackLayout Spacing="12" Padding="0,0,12,16">

                    <!-- HERO: newest saved image, large. Null job propagates to a null path,
                         so NonEmptyStringToBool hides the whole block until the first save. -->
                    <VerticalStackLayout Spacing="8"
                                         IsVisible="{Binding LatestCompletedJob.ResultPath, Converter={StaticResource NonEmptyStringToBool}}">
                        <Label Text="Latest result" Style="{StaticResource CardTitle}" />
                        <Border Stroke="{AppThemeBinding Light={StaticResource SurfaceBorderLight}, Dark={StaticResource SurfaceBorderDark}}"
                                StrokeThickness="1"
                                Padding="0">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="8" />
                            </Border.StrokeShape>
                            <Image Source="{Binding LatestCompletedJob.ResultPath}"
                                   Aspect="AspectFit"
                                   MaximumHeightRequest="560"
                                   HorizontalOptions="Fill"
                                   SemanticProperties.Description="Newest generated image. Tap to open full size."
                                   AutomationId="HeroResultImage">
                                <Image.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding LatestCompletedJob.OpenImageCommand}" />
                                </Image.GestureRecognizers>
                            </Image>
                        </Border>
                        <HorizontalStackLayout Spacing="8">
                            <Label Text="Tap to open full size."
                                   Style="{StaticResource HelperText}"
                                   VerticalOptions="Center" />
                            <Button Text="Use as input"
                                    Command="{Binding LatestCompletedJob.UseAsInputCommand}"
                                    Style="{StaticResource SecondaryButton}"
                                    AutomationId="HeroUseAsInputButton" />
                            <Button Text="Show in folder"
                                    Command="{Binding LatestCompletedJob.ShowInFolderCommand}"
                                    Style="{StaticResource SecondaryButton}"
                                    AutomationId="HeroShowInFolderButton" />
                        </HorizontalStackLayout>
                    </VerticalStackLayout>

                    <Label Text="Generation Queue"
                           Style="{StaticResource CardTitle}"
                           IsVisible="{Binding HasJobs}" />
                    <VerticalStackLayout BindableLayout.ItemsSource="{Binding Jobs}" Spacing="12">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate x:DataType="vm:GenerationJob">
                                <Border Style="{StaticResource Card}">
                                    <VerticalStackLayout Spacing="8">

                                        <!-- Prompt (full, wrapping) -->
                                        <Label Text="{Binding Prompt}"
                                               Style="{StaticResource FieldLabel}"
                                               LineBreakMode="WordWrap" />

                                        <!-- Model · AR · seed -->
                                        <Label Text="{Binding MetaLine}" Style="{StaticResource HelperText}" />

                                        <!-- Live sampler progress (ComfyUI ws); appears with the first
                                             step report, disappears with the final outcome. -->
                                        <ProgressBar Progress="{Binding Progress}"
                                                     IsVisible="{Binding HasProgress}"
                                                     AutomationId="JobProgressBar" />

                                        <!-- Status row: spinner (if running) + status text (always) + Cancel (if running) -->
                                        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8">
                                            <ActivityIndicator Grid.Column="0"
                                                               IsRunning="{Binding IsRunning}"
                                                               IsVisible="{Binding IsRunning}"
                                                               HeightRequest="18" WidthRequest="18"
                                                               VerticalOptions="Center" />
                                            <Label Grid.Column="1"
                                                   Text="{Binding StatusMessage}"
                                                   VerticalOptions="Center"
                                                   LineBreakMode="TailTruncation"
                                                   MaxLines="2">
                                                <Label.Triggers>
                                                    <DataTrigger TargetType="Label" Binding="{Binding StatusKind}" Value="{x:Static vm:StatusKind.Success}">
                                                        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource StatusSuccessLight}, Dark={StaticResource StatusSuccessDark}}" />
                                                    </DataTrigger>
                                                    <DataTrigger TargetType="Label" Binding="{Binding StatusKind}" Value="{x:Static vm:StatusKind.Error}">
                                                        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource StatusErrorLight}, Dark={StaticResource StatusErrorDark}}" />
                                                    </DataTrigger>
                                                    <DataTrigger TargetType="Label" Binding="{Binding StatusKind}" Value="{x:Static vm:StatusKind.Canceled}">
                                                        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource StatusCanceledLight}, Dark={StaticResource StatusCanceledDark}}" />
                                                    </DataTrigger>
                                                </Label.Triggers>
                                            </Label>
                                            <Button Grid.Column="2"
                                                    Text="Cancel"
                                                    Command="{Binding CancelCommand}"
                                                    Style="{StaticResource DangerButton}"
                                                    IsVisible="{Binding IsRunning}"
                                                    AutomationId="JobCancelButton" />
                                        </Grid>

                                        <!-- Result thumbnail (tap to open) -->
                                        <Border IsVisible="{Binding ResultPath, Converter={StaticResource NonEmptyStringToBool}}"
                                                Stroke="{AppThemeBinding Light={StaticResource SurfaceBorderLight}, Dark={StaticResource SurfaceBorderDark}}"
                                                StrokeThickness="1"
                                                Padding="0">
                                            <Border.StrokeShape>
                                                <RoundRectangle CornerRadius="8" />
                                            </Border.StrokeShape>
                                            <Image Source="{Binding ResultPath}"
                                                   Aspect="AspectFill"
                                                   HeightRequest="260"
                                                   HorizontalOptions="Fill"
                                                   SemanticProperties.Description="Generated image. Tap to open full size.">
                                                <Image.GestureRecognizers>
                                                    <TapGestureRecognizer Command="{Binding OpenImageCommand}" />
                                                </Image.GestureRecognizers>
                                            </Image>
                                        </Border>

                                        <!-- Action buttons (when complete) -->
                                        <HorizontalStackLayout Spacing="8"
                                                               IsVisible="{Binding ResultPath, Converter={StaticResource NonEmptyStringToBool}}">
                                            <Label Text="Tap thumbnail to open full size."
                                                   Style="{StaticResource HelperText}"
                                                   VerticalOptions="Center" />
                                            <Button Text="Use as input"
                                                    Command="{Binding UseAsInputCommand}"
                                                    Style="{StaticResource SecondaryButton}"
                                                    AutomationId="JobUseAsInputButton" />
                                            <Button Text="Show in folder"
                                                    Command="{Binding ShowInFolderCommand}"
                                                    Style="{StaticResource SecondaryButton}"
                                                    AutomationId="JobShowInFolderButton" />
                                        </HorizontalStackLayout>

                                        <!-- CivitAI posting status (post-save side effect; collapsed unless posting ran) -->
                                        <HorizontalStackLayout Spacing="8"
                                                               IsVisible="{Binding CivitaiStatusMessage, Converter={StaticResource NonEmptyStringToBool}}">
                                            <Label Text="{Binding CivitaiStatusMessage}"
                                                   Style="{StaticResource HelperText}"
                                                   VerticalOptions="Center"
                                                   LineBreakMode="TailTruncation"
                                                   MaxLines="2"
                                                   AutomationId="JobCivitaiStatusLabel" />
                                            <Button Text="Open post"
                                                    Command="{Binding OpenCivitaiPostCommand}"
                                                    Style="{StaticResource SecondaryButton}"
                                                    IsVisible="{Binding CivitaiPostUrl, Converter={StaticResource NonEmptyStringToBool}}"
                                                    AutomationId="JobOpenCivitaiPostButton" />
                                        </HorizontalStackLayout>

                                    </VerticalStackLayout>
                                </Border>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </VerticalStackLayout>

                </VerticalStackLayout>
            </ScrollView>
        </Grid>

        <!-- ACTION BAR: always visible, replaces the old "Run" card. -->
        <Border Grid.Row="2" Style="{StaticResource ActionBar}">
            <Grid RowDefinitions="Auto,Auto"
                  RowSpacing="4"
                  ColumnDefinitions="Auto,Auto,Auto,Auto,*"
                  ColumnSpacing="8">

                <Button x:Name="GenerateButton"
                        Grid.Row="0" Grid.Column="0"
                        Text="Generate Image"
                        Style="{StaticResource ActionPrimary}"
                        Command="{Binding GenerateImageCommand}"
                        IsEnabled="{Binding IsValid}"
                        MinimumWidthRequest="170"
                        VerticalOptions="Center"
                        ToolTipProperties.Text="Start image generation (Ctrl+Enter)"
                        SemanticProperties.Description="Start image generation"
                        AutomationId="GenerateButton" />

                <!-- Import and Cancel batch share the cell: their IsVisible bindings are
                     mutually exclusive, so the bar never jumps when a batch starts. -->
                <Button Grid.Row="0" Grid.Column="1"
                        Text="Import prompts…"
                        Style="{StaticResource SecondaryButton}"
                        Clicked="OnImportPromptsClicked"
                        IsVisible="{Binding Batch.IsBatchRunning, Converter={StaticResource InverseBool}}"
                        VerticalOptions="Center"
                        SemanticProperties.Description="Pick a textfile of prompts (separated by blank lines, # comments, or ---) and run them sequentially with the current model and settings"
                        AutomationId="ImportPromptsButton" />

                <Button Grid.Row="0" Grid.Column="1"
                        Text="Cancel batch"
                        Style="{StaticResource SecondaryButton}"
                        Command="{Binding Batch.CancelBatchCommand}"
                        IsVisible="{Binding Batch.IsBatchRunning}"
                        VerticalOptions="Center"
                        SemanticProperties.Description="Stop the running batch and cancel queued prompts"
                        AutomationId="CancelBatchButton" />

                <Button Grid.Row="0" Grid.Column="2"
                        Text="Open output folder"
                        Command="{Binding OpenOutputFolderCommand}"
                        Style="{StaticResource SecondaryButton}"
                        VerticalOptions="Center"
                        SemanticProperties.Description="Open the generated-images folder in Explorer"
                        AutomationId="OpenFolderButton" />

                <Button Grid.Row="0" Grid.Column="3"
                        Text="Gallery"
                        Command="{Binding OpenGalleryCommand}"
                        Style="{StaticResource SecondaryButton}"
                        VerticalOptions="Center"
                        SemanticProperties.Description="Browse previously generated images"
                        AutomationId="OpenGalleryButton" />

                <VerticalStackLayout Grid.Row="0" Grid.Column="4"
                                     VerticalOptions="Center"
                                     Spacing="2">
                    <!-- Transient toast — auto-clears after a couple of seconds. Distinct
                         from the form-level Status label below (which sticks). -->
                    <Label Text="{Binding FlashMessage}"
                           IsVisible="{Binding FlashMessage, Converter={StaticResource NonEmptyStringToBool}}"
                           TextColor="{AppThemeBinding Light={StaticResource StatusSuccessLight}, Dark={StaticResource StatusSuccessDark}}"
                           FontAttributes="Bold"
                           LineBreakMode="TailTruncation"
                           MaxLines="1"
                           AutomationId="FlashLabel" />

                    <!-- Status (form-level errors and info); tooltip carries the full text
                         past the 2-line truncation. -->
                    <Label Text="{Binding StatusMessage}"
                           Style="{StaticResource StatusLabel}"
                           IsVisible="{Binding StatusMessage, Converter={StaticResource NonEmptyStringToBool}}"
                           LineBreakMode="TailTruncation"
                           MaxLines="2"
                           ToolTipProperties.Text="{Binding StatusMessage}"
                           AutomationId="StatusLabel">
                        <Label.Triggers>
                            <DataTrigger TargetType="Label" Binding="{Binding StatusKind}" Value="{x:Static vm:StatusKind.Success}">
                                <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource StatusSuccessLight}, Dark={StaticResource StatusSuccessDark}}" />
                            </DataTrigger>
                            <DataTrigger TargetType="Label" Binding="{Binding StatusKind}" Value="{x:Static vm:StatusKind.Error}">
                                <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource StatusErrorLight}, Dark={StaticResource StatusErrorDark}}" />
                            </DataTrigger>
                            <DataTrigger TargetType="Label" Binding="{Binding StatusKind}" Value="{x:Static vm:StatusKind.Warning}">
                                <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource StatusWarningLight}, Dark={StaticResource StatusWarningDark}}" />
                            </DataTrigger>
                            <DataTrigger TargetType="Label" Binding="{Binding StatusKind}" Value="{x:Static vm:StatusKind.Canceled}">
                                <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource StatusCanceledLight}, Dark={StaticResource StatusCanceledDark}}" />
                            </DataTrigger>
                            <DataTrigger TargetType="Label" Binding="{Binding StatusKind}" Value="{x:Static vm:StatusKind.Info}">
                                <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource StatusInfoLight}, Dark={StaticResource StatusInfoDark}}" />
                            </DataTrigger>
                        </Label.Triggers>
                    </Label>
                </VerticalStackLayout>

                <VerticalStackLayout Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="5" Spacing="2">
                    <Label Text="Enter a prompt to enable generation. Replicate-hosted models also need an API token — set it under Settings (top right)."
                           Style="{StaticResource HelperText}"
                           IsVisible="{Binding IsValid, Converter={StaticResource InverseBool}}" />
                    <Label Text="Pick a .txt file. Prompts are separated by a blank line, a # comment line, or a line with only ---. Lines starting with # are ignored."
                           Style="{StaticResource HelperText}"
                           IsVisible="{Binding Batch.IsBatchRunning, Converter={StaticResource InverseBool}}" />
                </VerticalStackLayout>
            </Grid>
        </Border>

    </Grid>
</ContentPage>
