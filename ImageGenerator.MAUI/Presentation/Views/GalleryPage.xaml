<?xml version="1.0" encoding="UTF-8"?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:converters="clr-namespace:ImageGenerator.MAUI.Presentation.Converters"
             xmlns:entities="clr-namespace:ImageGenerator.MAUI.Core.Domain.Entities"
             xmlns:vm="clr-namespace:ImageGenerator.MAUI.Presentation.ViewModels"
             x:Name="Root"
             x:Class="ImageGenerator.MAUI.Presentation.Views.GalleryPage"
             x:DataType="vm:GalleryViewModel"
             Title="Gallery"
             Shell.NavBarIsVisible="False"
             Padding="0">
    <ContentPage.Resources>
        <ResourceDictionary>
            <converters:InverseBoolConverter x:Key="InverseBool" />
            <converters:ShellThumbnailConverter x:Key="ShellThumbnail" />
            <converters:NonEmptyStringToBoolConverter x:Key="NonEmptyStringToBool" />
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto,Auto,Auto,*"
          Padding="24,16,24,12"
          RowSpacing="12">

        <!-- Header -->
        <Grid Grid.Row="0" ColumnDefinitions="*,Auto,Auto" ColumnSpacing="12">
            <VerticalStackLayout Grid.Column="0" Spacing="4" VerticalOptions="Center">
                <Label Text="Gallery" Style="{StaticResource CardTitle}" />
                <Label Text="Browse generated images. Tap a tile to select; use Open to view, or select several and post them to CivitAI."
                       Style="{StaticResource HelperText}" />
                <HorizontalStackLayout Spacing="8" VerticalOptions="Center">
                    <Label Text="Sort by:" Style="{StaticResource FieldLabel}" VerticalOptions="Center" />
                    <Picker ItemsSource="{Binding SortModes}"
                            SelectedItem="{Binding SelectedSortMode}"
                            MaximumWidthRequest="180"
                            HorizontalOptions="Start"
                            AutomationId="GallerySortPicker" />
                </HorizontalStackLayout>
            </VerticalStackLayout>
            <Button Grid.Column="1"
                    Text="Refresh"
                    Command="{Binding RefreshCommand}"
                    Style="{StaticResource SecondaryButton}"
                    VerticalOptions="Start"
                    AutomationId="GalleryRefreshButton" />
            <Button Grid.Column="2"
                    Text="Open folder"
                    Command="{Binding OpenOutputFolderCommand}"
                    Style="{StaticResource SecondaryButton}"
                    VerticalOptions="Start"
                    AutomationId="GalleryOpenFolderButton" />
        </Grid>

        <!-- Busy + empty hints -->
        <ActivityIndicator Grid.Row="1"
                           IsRunning="{Binding IsBusy}"
                           IsVisible="{Binding IsBusy}"
                           HorizontalOptions="Center" />

        <Label Grid.Row="1"
               Text="No images yet — generate something on the Generate page."
               Style="{StaticResource HelperText}"
               IsVisible="{Binding IsEmpty}"
               HorizontalOptions="Center"
               Padding="0,8" />

        <!-- CivitAI batch-post action bar — appears only with a selection. Posts all selected
             images into ONE draft post; the warning dialog (code-behind) precedes the upload. -->
        <Border Grid.Row="2"
                Style="{StaticResource Card}"
                Padding="10"
                IsVisible="{Binding HasSelection}">
            <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="*,Auto,Auto,Auto" ColumnSpacing="10" RowSpacing="6">
                <Entry Grid.Row="0" Grid.Column="0" Text="{Binding CivitaiModelRef}"
                       Placeholder="Optional CivitAI model URL or version id"
                       VerticalOptions="Center" AutomationId="GalleryCivitaiModelRefEntry" />
                <HorizontalStackLayout Grid.Row="0" Grid.Column="1" Spacing="4" VerticalOptions="Center">
                    <Switch IsToggled="{Binding CivitaiIncludeMeta}" AutomationId="GalleryCivitaiIncludeMetaSwitch" />
                    <Label Text="Metadata" Style="{StaticResource HelperText}" VerticalOptions="Center" />
                </HorizontalStackLayout>
                <Button Grid.Row="0" Grid.Column="2" Text="Breed variants"
                        Command="{Binding BreedSelectedCommand}" Style="{StaticResource SecondaryButton}"
                        AutomationId="GalleryBreedSelectedButton" />
                <Button Grid.Row="0" Grid.Column="3" Text="Post to CivitAI"
                        Clicked="OnPostToCivitaiClicked" Style="{StaticResource PrimaryButton}"
                        IsEnabled="{Binding IsPosting, Converter={StaticResource InverseBool}}"
                        AutomationId="GalleryPostCivitaiButton" />
                <HorizontalStackLayout Grid.Row="1" Grid.ColumnSpan="4" Spacing="8">
                    <ActivityIndicator IsRunning="{Binding IsPosting}" IsVisible="{Binding IsPosting}" HeightRequest="18" WidthRequest="18" />
                    <Label Text="{Binding CivitaiStatusMessage}" IsVisible="{Binding CivitaiStatusMessage, Converter={StaticResource NonEmptyStringToBool}}"
                           Style="{StaticResource HelperText}" AutomationId="GalleryCivitaiStatusLabel" />
                    <Label Text="{Binding BreedStatusMessage}" IsVisible="{Binding BreedStatusMessage, Converter={StaticResource NonEmptyStringToBool}}"
                           Style="{StaticResource HelperText}" AutomationId="GalleryBreedStatusLabel" />
                    <Button Text="Open draft" Command="{Binding OpenLastPostCommand}" Style="{StaticResource SecondaryButton}"
                            IsVisible="{Binding HasLastPost}" AutomationId="GalleryOpenDraftButton" />
                </HorizontalStackLayout>
            </Grid>
        </Border>

        <!-- Tile grid -->
        <CollectionView Grid.Row="3"
                        ItemsSource="{Binding Items}"
                        SelectionMode="Multiple"
                        SelectedItems="{Binding SelectedItems}"
                        SizeChanged="OnGallerySizeChanged"
                        AutomationId="GalleryCollection">
            <CollectionView.ItemsLayout>
                <GridItemsLayout Orientation="Vertical"
                                 Span="4"
                                 HorizontalItemSpacing="12"
                                 VerticalItemSpacing="12" />
            </CollectionView.ItemsLayout>
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="entities:GalleryItem">
                    <!-- The Border is the item root, so the CollectionView drives its Selected
                         visual state. Tapping a tile toggles selection (multi-select); Open and
                         Show metadata are explicit buttons (code-behind handlers, because
                         RelativeSource lookups don't reliably cross the DataTemplate scope). -->
                    <Border Style="{StaticResource Card}"
                            Padding="8">
                        <VisualStateManager.VisualStateGroups>
                            <VisualStateGroup x:Name="CommonStates">
                                <VisualState x:Name="Normal" />
                                <VisualState x:Name="Selected">
                                    <VisualState.Setters>
                                        <Setter Property="Stroke" Value="{StaticResource Primary}" />
                                        <Setter Property="StrokeThickness" Value="3" />
                                    </VisualState.Setters>
                                </VisualState>
                            </VisualStateGroup>
                        </VisualStateManager.VisualStateGroups>
                        <VerticalStackLayout Spacing="6">
                            <Image Source="{Binding FilePath, Converter={StaticResource ShellThumbnail}}"
                                   Aspect="AspectFit"
                                   HeightRequest="200"
                                   WidthRequest="200"
                                   HorizontalOptions="Center"
                                   SemanticProperties.Description="{Binding FileName}" />
                            <Label Text="{Binding FileName}"
                                   Style="{StaticResource HelperText}"
                                   LineBreakMode="TailTruncation"
                                   MaxLines="1"
                                   HorizontalOptions="Fill"
                                   HorizontalTextAlignment="Center"
                                   ToolTipProperties.Text="{Binding FileName}" />
                            <HorizontalStackLayout Spacing="6" HorizontalOptions="Center">
                                <Button Text="View"
                                        Style="{StaticResource SecondaryButton}"
                                        CommandParameter="{Binding .}"
                                        Clicked="OnOpenTileClicked"
                                        AutomationId="GalleryOpenTileButton" />
                                <Button Text="Details"
                                        Style="{StaticResource SecondaryButton}"
                                        CommandParameter="{Binding .}"
                                        Clicked="OnShowMetadataClicked"
                                        AutomationId="GalleryShowMetadataButton" />
                            </HorizontalStackLayout>
                        </VerticalStackLayout>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>
