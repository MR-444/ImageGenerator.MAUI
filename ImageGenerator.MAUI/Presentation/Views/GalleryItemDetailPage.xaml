<?xml version="1.0" encoding="UTF-8"?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:converters="clr-namespace:ImageGenerator.MAUI.Presentation.Converters"
             xmlns:vm="clr-namespace:ImageGenerator.MAUI.Presentation.ViewModels"
             x:Class="ImageGenerator.MAUI.Presentation.Views.GalleryItemDetailPage"
             x:DataType="vm:GalleryItemDetailViewModel"
             Title="Image details"
             Shell.NavBarIsVisible="False"
             Padding="0">
    <ContentPage.Resources>
        <ResourceDictionary>
            <converters:NonEmptyStringToBoolConverter x:Key="NonEmptyStringToBool" />
            <converters:ShellPreviewConverter x:Key="ShellPreview" />
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto,*,Auto,Auto"
          Padding="24,16,24,12"
          RowSpacing="12">

        <!-- Header row: Back button + filename + summary. The window's X closes the
             whole app (it's the OS chrome, not in-app), so we provide an explicit
             close action here. -->
        <Grid Grid.Row="0" ColumnDefinitions="Auto,*" ColumnSpacing="12">
            <Button Grid.Column="0"
                    Text="← Back"
                    Command="{Binding CloseCommand}"
                    Style="{StaticResource SecondaryButton}"
                    VerticalOptions="Start"
                    AutomationId="DetailBackButton" />
            <VerticalStackLayout Grid.Column="1" Spacing="4" VerticalOptions="Center">
                <Label Text="{Binding FileName}"
                       Style="{StaticResource CardTitle}"
                       LineBreakMode="MiddleTruncation" />
                <Label Text="{Binding Summary}"
                       Style="{StaticResource HelperText}"
                       IsVisible="{Binding Summary, Converter={StaticResource NonEmptyStringToBool}}" />
            </VerticalStackLayout>
        </Grid>

        <!-- Preview via the OS shell at SingleItem mode (~1024 px, aspect preserved).
             Direct file-path binding worked but occasionally hard-failed natively when
             MAUI's WIC pipeline hit a particular file mid-decode; the OS-rendered
             preview is sharper than the 256 px tile thumbnail and avoids that path.
             The image lives in its own star row (not inside a ScrollView) so AspectFit
             is measured against a bounded height and can't overflow past the metadata —
             a MaximumHeightRequest inside a ScrollView is ignored (infinite measure). -->
        <Image Grid.Row="1"
               Source="{Binding FilePath, Converter={StaticResource ShellPreview}}"
               Aspect="AspectFit"
               VerticalOptions="Fill"
               HorizontalOptions="Center"
               SemanticProperties.Description="{Binding FileName}" />

        <!-- Read-only but selectable; the Editor lets the user copy partial text by hand.
             Capped height so long captions scroll inside the editor instead of growing
             the row and pushing the action bar off-screen. -->
        <Border Grid.Row="2" Style="{StaticResource Card}">
            <VerticalStackLayout Spacing="8">
                <HorizontalStackLayout Spacing="6">
                    <Button Text="Prompt" Clicked="OnPromptTabClicked" Style="{StaticResource SecondaryButton}" AutomationId="DetailPromptTab" />
                    <Button Text="Details" Clicked="OnDetailsTabClicked" Style="{StaticResource SecondaryButton}" AutomationId="DetailDetailsTab" />
                    <Button Text="Raw metadata" Clicked="OnRawTabClicked" Style="{StaticResource SecondaryButton}" AutomationId="DetailRawTab" />
                </HorizontalStackLayout>
                <Editor x:Name="PromptEditor" Text="{Binding PromptText}"
                        IsReadOnly="True" AutoSize="TextChanges" MinimumHeightRequest="120" MaximumHeightRequest="180"
                        AutomationId="DetailPromptEditor" />
                <Editor x:Name="DetailsEditor" Text="{Binding DetailsText}" IsVisible="False"
                        IsReadOnly="True" AutoSize="TextChanges" MinimumHeightRequest="120" MaximumHeightRequest="180"
                        AutomationId="DetailDetailsEditor" />
                <Editor x:Name="RawMetadataEditor" Text="{Binding MetadataText}" IsVisible="False"
                        IsReadOnly="True"
                        AutoSize="TextChanges"
                        FontFamily="OpenSansRegular"
                        MinimumHeightRequest="160"
                        MaximumHeightRequest="220"
                        AutomationId="DetailMetadataEditor" />
            </VerticalStackLayout>
        </Border>

        <Border Grid.Row="3" Style="{StaticResource ActionBar}">
            <Grid RowDefinitions="Auto,Auto" RowSpacing="2">
                <FlexLayout Grid.Row="0"
                            Direction="Row"
                            Wrap="Wrap"
                            JustifyContent="Start"
                            AlignItems="Center">
                    <Button Text="Remix"
                            Command="{Binding RemixCommand}"
                            Style="{StaticResource ActionPrimary}"
                            Margin="0,0,8,6"
                            AutomationId="DetailRemixButton" />
                    <Button Text="Mutate from this"
                            Command="{Binding MutateFromImageCommand}"
                            Style="{StaticResource SecondaryButton}"
                            Margin="0,0,8,6"
                            AutomationId="DetailMutateFromImageButton" />
                    <Button Text="Save style"
                            Clicked="OnSaveStyleClicked"
                            Style="{StaticResource SecondaryButton}"
                            Margin="0,0,8,6"
                            AutomationId="DetailSaveStyleButton" />
                    <Button Text="Copy metadata"
                            Command="{Binding CopyMetadataCommand}"
                            Style="{StaticResource SecondaryButton}"
                            Margin="0,0,8,6"
                            AutomationId="DetailCopyButton" />
                    <Button Text="Use as input"
                            Command="{Binding UseAsInputCommand}"
                            Style="{StaticResource SecondaryButton}"
                            Margin="0,0,8,6"
                            AutomationId="DetailUseAsInputButton" />
                    <Button Text="Open in viewer"
                            Command="{Binding OpenInViewerCommand}"
                            Style="{StaticResource SecondaryButton}"
                            Margin="0,0,8,6"
                            AutomationId="DetailOpenButton" />
                    <Button Text="Show in folder"
                            Command="{Binding ShowInFolderCommand}"
                            Style="{StaticResource SecondaryButton}"
                            Margin="0,0,0,6"
                            AutomationId="DetailShowInFolderButton" />
                </FlexLayout>

                <!-- Transient toast from detail actions. -->
                <Label Grid.Row="1"
                       Text="{Binding FlashMessage}"
                       IsVisible="{Binding FlashMessage, Converter={StaticResource NonEmptyStringToBool}}"
                       TextColor="{AppThemeBinding Light={StaticResource StatusSuccessLight}, Dark={StaticResource StatusSuccessDark}}"
                       FontAttributes="Bold"
                       LineBreakMode="WordWrap"
                       MaxLines="2"
                       VerticalOptions="Center"
                       AutomationId="DetailFlashLabel" />
            </Grid>
        </Border>

    </Grid>
</ContentPage>
