<?xml version="1.0" encoding="UTF-8"?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:converters="clr-namespace:ImageGenerator.MAUI.Presentation.Converters"
             xmlns:vm="clr-namespace:ImageGenerator.MAUI.Presentation.ViewModels"
             x:Class="ImageGenerator.MAUI.Presentation.Views.SettingsPage"
             x:DataType="vm:GeneratorViewModel"
             Title="Settings"
             Shell.NavBarIsVisible="True"
             Padding="0">
    <ContentPage.Resources>
        <ResourceDictionary>
            <converters:NonEmptyStringToBoolConverter x:Key="NonEmptyStringToBool" />
        </ResourceDictionary>
    </ContentPage.Resources>

    <ScrollView>
        <VerticalStackLayout Padding="24"
                             Spacing="20"
                             MaximumWidthRequest="560"
                             HorizontalOptions="Start">

            <!-- CARD: Appearance -->
            <Border Style="{StaticResource Card}"
                    VerticalOptions="Start">
                <VerticalStackLayout Spacing="8">
                    <Label Text="Appearance" Style="{StaticResource CardTitle}" />
                    <!-- The whole UI is already AppThemeBinding-driven, so this just selects which
                         variant to force. System follows the OS (the app's original behavior). The
                         picker's SelectedIndex maps straight onto the AppTheme enum: 0=Unspecified
                         (System), 1=Light, 2=Dark — keep this order in sync with AppThemeIndex. -->
                    <Label Text="Choose the color theme. System follows your Windows setting."
                           Style="{StaticResource HelperText}" />
                    <Picker SelectedIndex="{Binding AppThemeIndex, Mode=TwoWay}"
                            SemanticProperties.Description="Color theme"
                            AutomationId="AppThemePicker">
                        <Picker.ItemsSource>
                            <x:Array Type="{x:Type x:String}">
                                <x:String>System</x:String>
                                <x:String>Light</x:String>
                                <x:String>Dark</x:String>
                            </x:Array>
                        </Picker.ItemsSource>
                    </Picker>
                </VerticalStackLayout>
            </Border>

            <!-- CARD: API Tokens (one row per provider, switch via the picker) -->
            <Border Style="{StaticResource Card}"
                    VerticalOptions="Start">
                <VerticalStackLayout Spacing="8">
                    <Label Text="API Tokens" Style="{StaticResource CardTitle}" />
                    <Label Text="Each provider has its own token slot, stored separately in OS secure storage. Switch tabs to edit a different one."
                           Style="{StaticResource HelperText}" />

                    <Picker ItemsSource="{Binding TokenProviders}"
                            SelectedItem="{Binding SelectedTokenProvider}"
                            AutomationId="TokenProviderPicker">
                        <Picker.ItemDisplayBinding>
                            <Binding Path="DisplayName" x:DataType="vm:TokenProviderViewModel" />
                        </Picker.ItemDisplayBinding>
                    </Picker>

                    <Label Text="{Binding SelectedTokenProvider.HelperText}"
                           Style="{StaticResource HelperText}" />

                    <!-- Same split binding as the prompt Editor: WinUI TwoWay Text bindings can stop
                         pushing view->VM after paste/clear/paste, and a token field is all paste. -->
                    <Entry Text="{Binding SelectedTokenProvider.Value, Mode=OneWay}"
                           TextChanged="OnTokenTextChanged"
                           Placeholder="{Binding SelectedTokenProvider.Placeholder}"
                           IsPassword="True"
                           SemanticProperties.Description="API token for the selected provider"
                           AutomationId="ApiTokenEntry" />

                    <Button Text="{Binding SelectedTokenProvider.ForgetButtonText}"
                            Command="{Binding ForgetSelectedTokenCommand}"
                            Style="{StaticResource SecondaryButton}"
                            IsEnabled="{Binding SelectedTokenProvider.Value, Converter={StaticResource NonEmptyStringToBool}}"
                            HorizontalOptions="Start"
                            SemanticProperties.Description="Clear the selected provider's saved token from secure storage"
                            AutomationId="ForgetTokenButton" />
                </VerticalStackLayout>
            </Border>

            <!-- CARD: ComfyUI server -->
            <Border Style="{StaticResource Card}"
                    VerticalOptions="Start">
                <VerticalStackLayout Spacing="8">
                    <Label Text="ComfyUI server" Style="{StaticResource CardTitle}" />
                    <!-- Non-secret server setting, not a token: plain Preferences-backed Entry. -->
                    <Label Text="URL of your ComfyUI instance (no token needed) — local default, or a LAN host started with --listen."
                           Style="{StaticResource HelperText}" />
                    <Entry Text="{Binding ComfyUiBaseUrl, Mode=TwoWay}"
                           Placeholder="http://127.0.0.1:8188"
                           Keyboard="Url"
                           SemanticProperties.Description="Base URL of the ComfyUI server"
                           AutomationId="ComfyUiBaseUrlEntry" />

                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12" Margin="0,8,0,0">
                        <VerticalStackLayout Grid.Column="0" Spacing="2">
                            <Label Text="Free GPU memory after rendering" Style="{StaticResource FieldLabel}" />
                            <Label Text="Unloads ComfyUI models when rendering is idle so the Ollama mutation tier has VRAM. Turn off to keep the checkpoint loaded for faster single-image iteration."
                                   Style="{StaticResource HelperText}" />
                        </VerticalStackLayout>
                        <Switch Grid.Column="1"
                                IsToggled="{Binding FreeVramAfterRendering, Mode=TwoWay}"
                                VerticalOptions="Center"
                                SemanticProperties.Description="Free ComfyUI GPU memory after rendering"
                                AutomationId="FreeVramAfterRenderingSwitch" />
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <!-- CARD: Local LLM (Ollama) -->
            <Border Style="{StaticResource Card}"
                    VerticalOptions="Start">
                <VerticalStackLayout Spacing="8">
                    <Label Text="Local LLM (Ollama)" Style="{StaticResource CardTitle}" />
                    <!-- The free "Local" tier of AI mutation: verifies the technical round-trip without
                         paying Anthropic. No token needed; output quality is not the goal here. -->
                    <Label Text="Local Ollama server for the AI mutation 'Local' tier — a free path to test the round-trip (no token). Output quality isn't guaranteed."
                           Style="{StaticResource HelperText}" />
                    <Entry Text="{Binding OllamaBaseUrl, Mode=TwoWay}"
                           Placeholder="http://fireengine:11434"
                           Keyboard="Url"
                           SemanticProperties.Description="Base URL of the local Ollama server"
                           AutomationId="OllamaBaseUrlEntry" />
                    <Label Text="Model" Style="{StaticResource FieldLabel}" />
                    <!-- Refresh pulls the installed models from the server; pick one. -->
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                        <Picker Grid.Column="0"
                                ItemsSource="{Binding OllamaModels}"
                                SelectedItem="{Binding OllamaModel, Mode=TwoWay}"
                                Title="Refresh, then pick a model…"
                                SemanticProperties.Description="Pick an installed Ollama model"
                                AutomationId="OllamaModelPicker" />
                        <Button Grid.Column="1"
                                Text="Refresh"
                                Command="{Binding RefreshOllamaModelsCommand}"
                                Style="{StaticResource SecondaryButton}"
                                SemanticProperties.Description="List models from the Ollama server"
                                AutomationId="OllamaModelRefreshButton" />
                    </Grid>
                    <Label Text="A 27B model cold-loads into VRAM on the first call — expect the first variant to take a few minutes."
                           Style="{StaticResource HelperText}" />
                </VerticalStackLayout>
            </Border>

            <!-- CARD: Output folder -->
            <Border Style="{StaticResource Card}"
                    VerticalOptions="Start">
                <VerticalStackLayout Spacing="8">
                    <Label Text="Output folder" Style="{StaticResource CardTitle}" />
                    <Label Text="Where generated images (and their JSON-prompt exports) are saved. ComfyUI workflow templates and the log stay in the default Pictures folder."
                           Style="{StaticResource HelperText}" />
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                        <Entry Grid.Column="0"
                               Text="{Binding OutputFolder, Mode=TwoWay}"
                               Placeholder="Pictures\ImageGenerator.MAUI"
                               SemanticProperties.Description="Folder where generated images are saved"
                               AutomationId="OutputFolderEntry" />
                        <Button Grid.Column="1"
                                Text="Browse…"
                                Command="{Binding BrowseOutputFolderCommand}"
                                Style="{StaticResource SecondaryButton}"
                                SemanticProperties.Description="Choose the output folder"
                                AutomationId="OutputFolderBrowseButton" />
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <!-- CARD: CivitAI -->
            <Border Style="{StaticResource Card}"
                    VerticalOptions="Start">
                <VerticalStackLayout Spacing="8">
                    <Label Text="CivitAI" Style="{StaticResource CardTitle}" />
                    <Label Text="Set the API key under API Tokens above (CivitAI tab). Posting needs the Media Write scope — a 'Full' key works; a free account is enough."
                           Style="{StaticResource HelperText}" />
                    <Button Text="Test connection"
                            Command="{Binding TestCivitaiConnectionCommand}"
                            Style="{StaticResource SecondaryButton}"
                            HorizontalOptions="Start"
                            SemanticProperties.Description="Verify the saved CivitAI API key"
                            AutomationId="CivitaiTestConnectionButton" />
                    <Label Text="{Binding CivitaiConnectionStatus}"
                           Style="{StaticResource HelperText}"
                           IsVisible="{Binding CivitaiConnectionStatus, Converter={StaticResource NonEmptyStringToBool}}"
                           AutomationId="CivitaiConnectionStatusLabel" />
                </VerticalStackLayout>
            </Border>

            <Label Text="Changes are saved as you type — tokens to OS secure storage, the server URL to app preferences."
                   Style="{StaticResource HelperText}" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
