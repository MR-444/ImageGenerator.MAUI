<?xml version="1.0" encoding="UTF-8" ?>
<?xaml-comp compile="true" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- Brand -->
    <Color x:Key="Primary">#4F6BED</Color>
    <Color x:Key="PrimaryDark">#8EA6FF</Color>
    <Color x:Key="PrimaryDarkText">#10131A</Color>
    <Color x:Key="Secondary">#E5EAFF</Color>
    <Color x:Key="SecondaryDarkText">#B8C5FF</Color>
    <Color x:Key="Tertiary">#3448A5</Color>
    <Color x:Key="AccentWarm">#F2B56B</Color>
    <Color x:Key="SelectionLight">#E8EDFF</Color>
    <Color x:Key="SelectionDark">#27345E</Color>
    <Color x:Key="CanvasDark">#111318</Color>

    <!-- Neutrals -->
    <Color x:Key="White">White</Color>
    <Color x:Key="Black">Black</Color>
    <Color x:Key="Magenta">#D600AA</Color>
    <Color x:Key="MidnightBlue">#190649</Color>
    <Color x:Key="OffBlack">#17191E</Color>

    <Color x:Key="Gray100">#E1E1E1</Color>
    <Color x:Key="Gray200">#C8C8C8</Color>
    <Color x:Key="Gray300">#ACACAC</Color>
    <Color x:Key="Gray400">#919191</Color>
    <Color x:Key="Gray500">#6E6E6E</Color>
    <Color x:Key="Gray600">#404040</Color>
    <Color x:Key="Gray900">#212121</Color>
    <Color x:Key="Gray950">#141414</Color>

    <!-- Surfaces (cards, panels) -->
    <Color x:Key="SurfaceLight">#FFFFFF</Color>
    <Color x:Key="SurfaceDark">#23262D</Color>
    <Color x:Key="SurfaceRaisedLight">#F7F8FB</Color>
    <Color x:Key="SurfaceRaisedDark">#2A2E37</Color>
    <Color x:Key="SurfaceBorderLight">#DDE1E8</Color>
    <Color x:Key="SurfaceBorderDark">#383D48</Color>

    <!-- Status palette — WCAG-AA against light/dark backgrounds -->
    <Color x:Key="StatusSuccessLight">#1B5E20</Color>
    <Color x:Key="StatusSuccessDark">#81C784</Color>
    <Color x:Key="StatusErrorLight">#B71C1C</Color>
    <Color x:Key="StatusErrorDark">#E57373</Color>
    <Color x:Key="StatusInfoLight">#424242</Color>
    <Color x:Key="StatusInfoDark">#BDBDBD</Color>
    <Color x:Key="StatusWarningLight">#E65100</Color>
    <Color x:Key="StatusWarningDark">#FFB74D</Color>
    <Color x:Key="StatusCanceledLight">#616161</Color>
    <Color x:Key="StatusCanceledDark">#9E9E9E</Color>

    <!-- Danger (cancel buttons) -->
    <Color x:Key="DangerLight">#C62828</Color>
    <Color x:Key="DangerDark">#EF5350</Color>

    <!-- Brushes -->
    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource Primary}"/>
    <SolidColorBrush x:Key="SecondaryBrush" Color="{StaticResource Secondary}"/>
    <SolidColorBrush x:Key="TertiaryBrush" Color="{StaticResource Tertiary}"/>
    <SolidColorBrush x:Key="WhiteBrush" Color="{StaticResource White}"/>
    <SolidColorBrush x:Key="BlackBrush" Color="{StaticResource Black}"/>

    <SolidColorBrush x:Key="Gray100Brush" Color="{StaticResource Gray100}"/>
    <SolidColorBrush x:Key="Gray200Brush" Color="{StaticResource Gray200}"/>
    <SolidColorBrush x:Key="Gray300Brush" Color="{StaticResource Gray300}"/>
    <SolidColorBrush x:Key="Gray400Brush" Color="{StaticResource Gray400}"/>
    <SolidColorBrush x:Key="Gray500Brush" Color="{StaticResource Gray500}"/>
    <SolidColorBrush x:Key="Gray600Brush" Color="{StaticResource Gray600}"/>
    <SolidColorBrush x:Key="Gray900Brush" Color="{StaticResource Gray900}"/>
    <SolidColorBrush x:Key="Gray950Brush" Color="{StaticResource Gray950}"/>
</ResourceDictionary>
